{
  "name": "clanka",
  "type": "module",
  "version": "0.2.49",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "clanka": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "husky && effect-language-service patch",
    "check": "oxlint -c .oxlintrc.json --fix && pnpm tsc -b tsconfig.json",
    "test": "vitest run",
    "build": "tsc -b tsconfig.json",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "author": "Tim Smart <hello@timsmart.co>",
  "homepage": "https://github.com/Effectful-Tech/clanka",
  "repository": {
    "type": "git",
    "url": "https://github.com/Effectful-Tech/clanka.git"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48",
  "dependencies": {
    "@effect/ai-openai": "4.0.0-beta.43",
    "@effect/platform-node": "4.0.0-beta.43",
    "@effect/sql-sqlite-node": "4.0.0-beta.43",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@vscode/ripgrep": "^1.17.1",
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "tree-sitter": "^0.21.0",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "turndown": "^7.2.2"
  },
  "optionalDependencies": {
    "@sqliteai/sqlite-vector-darwin-arm64": "0.9.93",
    "@sqliteai/sqlite-vector-darwin-x86_64": "0.9.93",
    "@sqliteai/sqlite-vector-linux-arm64": "0.9.93",
    "@sqliteai/sqlite-vector-linux-arm64-musl": "0.9.93",
    "@sqliteai/sqlite-vector-linux-x86_64": "0.9.93",
    "@sqliteai/sqlite-vector-linux-x86_64-musl": "0.9.93",
    "@sqliteai/sqlite-vector-win32-x86_64": "0.9.93"
  },
  "peerDependencies": {
    "@effect/ai-openai": "4.0.0-beta.43",
    "@effect/ai-openai-compat": "4.0.0-beta.43",
    "effect": "4.0.0-beta.43"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.8",
    "@effect/ai-openai-compat": "4.0.0-beta.43",
    "@effect/language-service": "^0.83.1",
    "@effect/vitest": "4.0.0-beta.43",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "effect": "4.0.0-beta.43",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.57.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/ripgrep",
      "better-sqlite3",
      "esbuild",
      "msgpackr-extract",
      "tree-sitter",
      "tree-sitter-javascript",
      "tree-sitter-typescript"
    ]
  }
}
