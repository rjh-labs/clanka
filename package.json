{
  "name": "clanka",
  "type": "module",
  "version": "0.0.28",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "husky && effect-language-service patch",
    "check": "oxlint -c .oxlintrc.json --fix && pnpm tsc -b tsconfig.json",
    "test": "vitest run",
    "build": "tsc -b tsconfig.json",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "author": "Tim Smart <hello@timsmart.co>",
  "homepage": "https://github.com/Effectful-Tech/clanka",
  "repository": {
    "type": "git",
    "url": "https://github.com/Effectful-Tech/clanka.git"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@vscode/ripgrep": "^1.17.0",
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "turndown": "^7.2.2"
  },
  "peerDependencies": {
    "@effect/ai-openai": "4.0.0-beta.31",
    "@effect/ai-openai-compat": "4.0.0-beta.31",
    "effect": "4.0.0-beta.31"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@effect/ai-openai": "4.0.0-beta.31",
    "@effect/ai-openai-compat": "4.0.0-beta.31",
    "@effect/language-service": "^0.75.1",
    "@effect/platform-node": "4.0.0-beta.31",
    "@effect/vitest": "4.0.0-beta.31",
    "@linear/sdk": "^75.0.0",
    "@types/node": "^25.3.5",
    "@types/turndown": "^5.0.6",
    "@typescript/native-preview": "7.0.0-dev.20260219.1",
    "effect": "4.0.0-beta.31",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxlint": "^1.49.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/ripgrep"
    ]
  }
}
